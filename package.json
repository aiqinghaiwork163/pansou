{
  "name": "wangpan",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --host --port 2005",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "vitest run",
    "audit": "npm audit",
    "build": "vite build",
    "preview": "vite preview",
    "deploy": "npm run build && wrangler pages deploy dist/static --project-name=wangpan",
    "deploy:prod": "npm run build && wrangler pages deploy dist/static --project-name=wangpan --branch=main"
  },
  "dependencies": {
    "@ant-design/icons": "^6.2.5",
    "@supabase/supabase-js": "^2.108.2",
    "antd": "^5.27.3",
    "clsx": "^2.1.1",
    "moment": "^2.30.1",
    "react": "^18.3.1",
    "react-datepicker": "^8.7.0",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.18.0",
    "sonner": "^2.0.2",
    "tailwind-merge": "^3.0.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "jsdom": "^29.1.1",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~5.7.2",
    "vite": "^6.2.0",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.1.9",
    "wrangler": "^4.103.0"
  }
}
